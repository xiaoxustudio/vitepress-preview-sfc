{
	"name": "@vitepress-preview-sfc/core",
	"version": "2.0.2",
	"description": "this is the core of the plugin",
	"main": "dist/index.cjs",
	"types": "dist/index.d.ts",
	"module": "dist/index.mjs",
	"type": "module",
	"exports": {
		".": {
			"import": {
				"types": "./dist/index.d.mts",
				"default": "./dist/index.mjs"
			},
			"require": {
				"types": "./dist/index.d.cts",
				"default": "./dist/index.js"
			}
		},
		"./types": {
			"import": {
				"types": "./dist/types.d.mts"
			},
			"require": {
				"types": "./dist/types.d.cts"
			}
		}
	},
	"scripts": {
		"watch": "tsdown -c tsdown.config.ts -w",
		"build": "tsdown -c tsdown.config.ts"
	},
	"repository": {
		"type": "git",
		"url": "git+https://github.com/xiaoxustudio/vitepress-preview-sfc.git",
		"directory": "packages/core"
	},
	"publishConfig": {
		"access": "public"
	},
	"files": [
		"dist"
	],
	"keywords": [
		"vitepress",
		"preview",
		"sfc",
		"vue",
		"markdown-it"
	],
	"author": "xuran",
	"license": "MIT",
	"peerDependencies": {
		"vue": "^3.4.0"
	},
	"devDependencies": {
		"@types/markdown-it": "^14.1.2",
		"@vitejs/plugin-vue": "^6.0.7",
		"tsdown": "^0.22.3",
		"typescript": "^5.8.3",
		"vue": "^3.5.33"
	}
}
